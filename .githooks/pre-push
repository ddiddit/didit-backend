#!/bin/zsh

echo "push 전 테스트 실행"

# macOS에서 GUI 앱/IDE로 푸시 시 PATH가 제한되므로 셸 프로파일 소싱
[ -f "$HOME/.zshrc" ] && source "$HOME/.zshrc" 2>/dev/null
[ -f "$HOME/.bash_profile" ] && source "$HOME/.bash_profile" 2>/dev/null

# JAVA_HOME 미설정 시 알려진 경로에서 자동 탐색
if [ -z "$JAVA_HOME" ] || ! "$JAVA_HOME/bin/java" -version &>/dev/null; then
  FOUND_JAVA=$(find "$HOME/.antigravity/extensions" -name "java" -path "*/jre/*/bin/java" 2>/dev/null | head -1)
  if [ -n "$FOUND_JAVA" ]; then
    export JAVA_HOME=$(dirname $(dirname "$FOUND_JAVA"))
    export PATH="$JAVA_HOME/bin:$PATH"
  fi
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

case "$(uname -s)" in
    Darwin*|Linux*)
        ./gradlew clean test
        ;;
    MINGW*|MSYS*)
        ./gradlew.bat clean test
        ;;
    *)
        echo "알 수 없는 운영체제입니다."
        exit 1
        ;;
esac

TEST_RESULT=$?

if [ $TEST_RESULT -ne 0 ]; then
    echo "테스트 실패: push가 중단되었습니다."
    exit 1
else
    echo "테스트 성공: push를 진행합니다."
    exit 0
fi
